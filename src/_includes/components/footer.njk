<footer class="max-w-[800px] lg:max-w-[1400px] mx-auto px-md pb-md">
  <div class=" mx-auto pt-md">
    <div class="flex flex-col md:flex-row justify-between">
      <div class="flex flex-col">
        <div class="py-2 h-12">
          <img src={{site.logo}} alt="Rebuild logo."/>
        </div>
        <p class="text-sm max-w-7xl">
          {{site.description }}</p>

        {# Newsletter signup form #}
        <div class="text-sm mt-lg">
          <p class="text-sm mb-xs">Get our newsletter or <a class="underline hover:text-blue" href="https://google.com">follow us on Linkedin</a>
          </p>
          <form
            id="footer-newsletter-form"
            action="{{ site.apiUrl }}/api/newsletter-signup"
            method="POST"
            class="flex flex-col gap-xs mb-md"
          >
            <div class="flex flex-col gap-xs">
              <input
                type="email"
                name="email"
                placeholder="Email"
                required
                class="w-full px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-blue"
              >

              <div class="flex flex-col sm:flex-row gap-xs">
                <input
                  type="text"
                  name="first_name"
                  placeholder="First name"
                  class="flex-1 px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-blue"
                >
                <input
                  type="text"
                  name="last_name"
                  placeholder="Last name"
                  class="flex-1 px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-blue"
                >
              </div>

              <select
                name="interest"
                required
                class="w-full px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-blue bg-light text-muted"
              >
                <option value="">Keep me up to date as...</option>
                <option value="entrepreneur">an entrepreneur</option>
                <option value="investor">an investor</option>
                <option value="fund">a public fund manager</option>
                <option value="media">a media representative</option>
                <option value="curious">a curious individual</option>
              </select>

              <div class="flex items-start gap-xs">
                <input
                  type="checkbox"
                  name="consent"
                  id="footer-consent"
                  required
                  class="mt-1 w-4 h-4 border-2 border-dark focus:ring-2 focus:ring-blue"
                >
                <label for="footer-consent" class="text-xs text-dark">
                  I consent to receive newsletters and updates from Rebuild. You can unsubscribe at any time.
                </label>
              </div>

              <button
                type="submit"
                class="text-sm px-sm py-xs bg-darker text-light hover:bg-dark text-left hover:underline self-start"
              >
                Subscribe
              </button>
            </div>
            <div id="footer-newsletter-success" class="hidden bg-green border-2 border-dark p-xs transition-opacity duration-300">
              <p class="text-dark text-xs font-semibold">Thanks for subscribing!</p>
            </div>
            <div id="footer-newsletter-error" class="hidden bg-red text-light border-2 border-dark p-xs transition-opacity duration-300">
              <p class="text-xs font-semibold">Something went wrong. Please try again.</p>
            </div>
          </form>

        </div>
      </div>

      {# NAVIGATION #}
      <nav class="flex text-sm flex-row gap-xl mt-xl md:mt-0" aria-label="Footer Navigation">
        <ul class="flex flex-col gap-sm md:gap-md list-none md:flex-wrap md:justify-top">
          {% for item in site.main_navigation %}
            <li>
              <a href="{{ item.url }}" class="text-dark hover:underline transition-fast hover:text-blue focus:text-blue">{{ item.name }}</a>
            </li>
          {% endfor %}
        </ul>
        <ul class="flex text-xs flex-col gap-sm list-none md:flex-wrap md:justify-top">
          {% for item in site.second_navigation %}
            <li>
              {% if item.clickable %}
                <a href="{{ item.url }}" class="hover:underline transition-fast hover:text-blue focus:text-blue">{{ item.name }}</a>
              {% else %}
                <span class="text-muted cursor-not-allowed">{{ item.name }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>
    <p class="text-dark text-xs mt-xl">&copy; 2025 {{ site.title }} All rights reserved.</p>
  </div>
</footer>

<script>
  // Footer newsletter form submission handler
  (function () {
    const form = document.getElementById('footer-newsletter-form');
    if (!form) 
      return;
    
    let fadeTimeout;

    function showMessage(element) {
      // Clear any existing timeout
      if (fadeTimeout) 
        clearTimeout(fadeTimeout);
      
      // Show the message
      element
        .classList
        .remove('hidden');
      element.style.opacity = '1';

      // Fade out after 3 seconds
      fadeTimeout = setTimeout(() => {
        element.style.opacity = '0';
        setTimeout(() => {
          element
            .classList
            .add('hidden');
        }, 300); // Wait for fade transition to complete
      }, 3000);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      e.stopImmediatePropagation(); // Prevent other handlers from firing
      const submitBtn = form.querySelector('button[type="submit"]');
      const successEl = document.getElementById('footer-newsletter-success');
      const errorEl = document.getElementById('footer-newsletter-error');

      // Hide both messages
      successEl
        .classList
        .add('hidden');
      errorEl
        .classList
        .add('hidden');

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Signing up...';

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          showMessage(successEl);
          form.reset();
        } else {
          showMessage(errorEl);
        }
      } catch (error) {
        console.error('Newsletter signup error:', error);
        showMessage(errorEl);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  })();
</script>