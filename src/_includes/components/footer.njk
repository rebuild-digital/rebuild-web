<footer class="max-w-[800px] lg:max-w-[1400px] mx-auto px-md mt-3xl">
  <div class="border-t-2 border-dark mx-auto pt-md">
    <div class="flex flex-col md:flex-row justify-between">
      <div class="flex flex-col">
        <p class="text-xl"> {{ site.title }}</p>
        <p class="text-sm max-w-7xl"> {{site.description }}</p>

        {# Newsletter signup form #}
        <div class="text-sm mt-lg">
          <p class="text-sm mb-xs">Get our newsletter</p>
          <form
            id="footer-newsletter-form"
            action="/api/newsletter-signup"
            method="POST"
            class="flex mb-md"
          >
            <div class="flex flex-col md:flex-row gap-xs md:gap-sm">
              <input
                type="text"
                name="first_name"
                placeholder="Firstname"
                required
                class="flex-1 px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-rb-blue"
              >
              <input
                type="email"
                name="email"
                placeholder="Email"
                required
                class="flex-1 px-sm py-xs border-2 border-dark text-sm focus:outline-none focus:ring-2 focus:ring-rb-blue"
              >
              <button
                type="submit"
                class="text-sm text-left hover:underline"
              >
                Subscribe
              </button>
            </div>
            <div id="footer-newsletter-success" class="hidden bg-rb-mint border-2 border-dark p-xs transition-opacity duration-300">
              <p class="text-dark text-xs font-semibold">Thanks for subscribing!</p>
            </div>
            <div id="footer-newsletter-error" class="hidden bg-rb-red text-off-white border-2 border-dark p-xs transition-opacity duration-300">
              <p class="text-xs font-semibold">Something went wrong. Please try again.</p>
            </div>
          </form>
          <a class="hover:underline hover:text-rb-blue" href="https://google.com">Follow us on Linkedin</a>
        </div>
      </div>

      {# NAVIGATION #}
        <nav class="flex text-sm flex-row gap-xl mt-xl md:mt-0" aria-label="Footer Navigation">
          <ul class="flex flex-col gap-sm md:gap-md list-none md:flex-wrap md:justify-top">
            {% for item in site.main_navigation %}
              <li>
                <a href="{{ item.url }}" class="text-dark hover:underline transition-fast hover:text-rb-blue focus:text-rb-blue">{{ item.name }}</a>
              </li>
            {% endfor %}
          </ul>
          <ul class="flex flex-col gap-sm md:gap-md list-none md:flex-wrap md:justify-top">
            {% for item in site.second_navigation %}
              <li>
                <a href="{{ item.url }}" class="hover:underline transition-fast hover:text-rb-blue focus:text-rb-blue">{{ item.name }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
    </div>
    <p class="text-dark text-xs mt-xl">&copy; 2025 {{ site.title }} All rights reserved.</p>
  </div>
</footer>

<script>
  // Footer newsletter form submission handler
  (function() {
    const form = document.getElementById('footer-newsletter-form');
    if (!form) return;

    let fadeTimeout;

    function showMessage(element) {
      // Clear any existing timeout
      if (fadeTimeout) clearTimeout(fadeTimeout);

      // Show the message
      element.classList.remove('hidden');
      element.style.opacity = '1';

      // Fade out after 3 seconds
      fadeTimeout = setTimeout(() => {
        element.style.opacity = '0';
        setTimeout(() => {
          element.classList.add('hidden');
        }, 300); // Wait for fade transition to complete
      }, 3000);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const successEl = document.getElementById('footer-newsletter-success');
      const errorEl = document.getElementById('footer-newsletter-error');

      // Hide both messages
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Signing up...';

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          showMessage(successEl);
          form.reset();
        } else {
          showMessage(errorEl);
        }
      } catch (error) {
        console.error('Newsletter signup error:', error);
        showMessage(errorEl);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  })();
</script>
