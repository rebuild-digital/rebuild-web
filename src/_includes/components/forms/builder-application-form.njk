{% set formId = 'builder-application-form' %}
{% set action = site.apiUrl + '/api/builder-application' %}
{% set method = 'POST' %}
{% set title = formTitle %}
{% set description = formDescription %}
{% set submitText = 'Submit' %}
{% set submitVariant = 'primary' %}
{% set fields = builderApplicationFields %}
{% set successMessage = 'Thank you for applying! We will review your application and get back to you soon.' %}
{% set errorMessage = 'Sorry, we could not submit your application. Please try again or contact us directly.' %}
{% include "components/form.njk" %}