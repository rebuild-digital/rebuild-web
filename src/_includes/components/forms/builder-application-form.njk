{#
  Builder Application Form
  Usage: {% include "components/builder-application-form.njk" %}

  This form allows builders to apply to become part of the Rebuild directory
  and potentially be featured. Submissions are sent to a Notion database
  via Bunny Edge Script (same database as promotions).

  Parameters:
  - title: Form title (optional, default provided)
  - description: Form description (optional, default provided)
  - featured: Boolean - if true, customizes for featured builder applications (default: false)
#}

{% set isFeatured = featured | default(false) %}

{% if isFeatured %}
  {% set formTitle = title | default('Apply to be a featured entrepreneur') %}
  {% set formDescription = description | default('Featured builders are highlighted in our directory and communications. Tell us about your work rebuilding social infrastructure in Europe.') %}
  {% set applicationType = 'featured' %}
{% else %}
  {% set formTitle = title | default('Join the directory') %}
  {% set formDescription = description | default('Are you working to rebuild social infrastructure in Europe? Join our directory of builders and connect with a community of like-minded changemakers.') %}
  {% set applicationType = 'standard' %}
{% endif %}

{% if isFeatured %}
  {# Fields for featured application #}
  {% set builderApplicationFields = [
    {
      type: 'text',
      name: 'builder_name',
      label: 'Your Name or Organization',
      placeholder: 'Jane Doe / Acme Rebuilders Co.',
      required: true
    }, {
      type: 'email',
      name: 'email',
      label: 'Email Address',
      placeholder: 'your@email.com',
      required: true
    }, {
      type: 'tel',
      name: 'phone',
      label: 'Phone Number',
      placeholder: '+45 12 34 56 78',
      required: false,
      helpText: 'Optional: In case we need to reach you'
    }, {
      type: 'url',
      name: 'website',
      label: 'Website or LinkedIn',
      placeholder: 'https://example.com',
      required: true,
      helpText: 'Where can people learn more about your work?'
    }, {
      type: 'select',
      name: 'category',
      label: 'Primary Focus Area',
      required: true,
      options: [
        'Technology & Software',
        'Social Enterprise',
        'Community Building',
        'Education & Training',
        'Policy & Advocacy',
        'Arts & Culture',
        'Environment & Sustainability',
        'Other'
      ]
    }, {
      type: 'select',
      name: 'location',
      label: 'Primary Location',
      required: true,
      placeholder: 'Select your country',
      options: [
        'Denmark',
        'Sweden',
        'Norway',
        'Finland',
        'Iceland',
        'Germany',
        'France',
        'Netherlands',
        'Belgium',
        'United Kingdom',
        'Ireland',
        'Spain',
        'Portugal',
        'Italy',
        'Switzerland',
        'Austria',
        'Poland',
        'Czech Republic',
        'Other European Country'
      ]
    }, {
      type: 'textarea',
      name: 'description',
      label: 'What are you building?',
      placeholder: 'Describe your project, initiative, or organization...',
      required: true,
      rows: 6,
      helpText: 'Tell us about your work and how it contributes to rebuilding social infrastructure'
    }, {
      type: 'textarea',
      name: 'impact',
      label: 'What impact have you made?',
      placeholder: 'Share metrics, stories, or outcomes...',
      required: true,
      rows: 4,
      helpText: 'Help us understand the reach and effectiveness of your work'
    }, {
      type: 'select',
      name: 'stage',
      label: 'Project Stage',
      required: true,
      options: ['Idea / Planning', 'Early Stage / Prototype', 'Growing / Scaling', 'Established / Mature']
    }, {
      type: 'text',
      name: 'team_size',
      label: 'Team Size',
      placeholder: 'e.g., 5 people, 20 volunteers, just me',
      required: false,
      helpText: 'Approximate number of people involved'
    }, {
      type: 'textarea',
      name: 'why_featured',
      label: 'Why should you be featured?',
      placeholder: 'What makes your work unique? What would you like to share with the Rebuild community?',
      required: true,
      rows: 4,
      helpText: 'Featured builders are highlighted in our communications and events'
    }, {
      type: 'url',
      name: 'social_media',
      label: 'Social Media Profile',
      placeholder: 'https://twitter.com/yourprofile or https://linkedin.com/in/yourprofile',
      required: false,
      helpText: 'Optional: Your most active social media presence'
    }, {
      type: 'checkbox',
      name: 'consent',
      label: 'I agree to be included in the Rebuild directory and understand that my information will be shared publicly.',
      required: true
    }, {
      type: 'checkbox',
      name: 'newsletter',
      label: 'I would like to receive updates from Rebuild (optional)',
      required: false
    }, {
      type: 'hidden',
      name: 'application_type',
      value: 'featured'
    }
  ] %}
{% else %}
  {# Fields for standard application #}
  {% set builderApplicationFields = [
    {
      type: 'text',
