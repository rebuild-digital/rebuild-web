{#
  Builder Promotion Form
  Usage: {% include "components/builder-promo-form.njk" %}

  This form allows users to promote a builder to the Rebuild directory.
  Submissions are sent to a Notion database via Bunny Edge Script.

  Parameters:
  - title: Form title (optional, default provided)
  - description: Form description (optional, default provided)
#}

{% set formTitle = title | default('Promote a builder') %}
{% set formDescription = description | default('Do you know of a promising startup or builder who should be in our directory? Let us know about them!') %}

{% set builderPromoFields = [
  {
    "type": "text",
    "name": "builder_name",
    "label": "Name",
    "placeholder": "Sleeve",
    "required": true,
    "helpText": "The name of the person or organization you want to promote"
  },
  {
    "type": "url",
    "name": "builder_website",
    "label": "Website or LinkedIn",
    "placeholder": "https://example.com",
    "required": true,
    "helpText": "Where can we learn more about this builder?"
  },
  {
    "type": "textarea",
    "name": "why_promote",
    "label": "Why should they be in the directory?",
    "placeholder": "Tell us what makes them special and how they are contributing to rebuilding social infrastructure in Europe.",
    "required": true,
    "rows": 5,
    "helpText": "Share what impact they are making and why the rebuild community should know about them."
  },
  {
    "type": "text",
    "name": "your_name",
    "label": "Your Name",
    "placeholder": "Your name",
    "required": false,
    "helpText": "Optional: Add if we can contact you later, if we need more information."
  },
  {
    "type": "email",
    "name": "your_email",
    "label": "Your Email",
    "placeholder": "your@email.com",
    "required": false,
    "helpText": "Optional: Add if we can contact you later, if we need more information."
  },
  {
    "type": "text",
    "name": "your_relationship",
    "label": "Your relationship to the promotion",
    "placeholder": "e.g., colleague, friend, community member",
    "required": false,
    "helpText": "Optional: How do you know this builder or startup? Add if we can contact you later, if we need more information."
  }
] %}

{% set formId = 'builder-promo-form' %}
{# TODO: Replace with your actual Bunny Edge Script URL from step 2j of deployment #}
{% set action = 'https://rebuild-applications-od76p.b-cdn.net/api/builder-promotion' %}
{% set method = 'POST' %}
{% set title = formTitle %}
{% set description = formDescription %}
{% set submitText = 'Submit Promotion' %}
{% set submitVariant = 'primary' %}
{% set fields = builderPromoFields %}
{% set successMessage = 'Thank you for the recommendation! We will review this builder for inclusion in our directory.' %}
{% set errorMessage = 'Sorry, we could not submit your promotion. Please try again or contact us directly.' %}
{% include "components/form.njk" %}
