  }, {
    type: 'email',
    name: 'email',
    label: 'Email',
    required: true
  }, {
    type: 'text',
    name: 'organisation',
    label: 'Organisation',
    required: true,
    helpText: 'What is your company/organisation called?'
  }, {
    type: 'select',
    name: 'country',
    label: 'Country',
    required: true,
    options: [
      'Albania',
