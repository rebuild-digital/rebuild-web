{#
  Tool Card Component

  Parameters:
  - version: Version number (e.g., "v0.8")
  - title: Tool title
  - description: Tool description
  - thumbnail: Image path for thumbnail
  - thumbnailAlt: Alt text for the thumbnail
  - primaryAction: Object with { text, url } for primary button
  - secondaryAction: Object with { text, url } for secondary button (optional)
  - label: String - custom label text to display in top-right corner (optional)
#}

<div class="border-2 border-dark bg-lighter flex flex-col h-full">
  {# Thumbnail #}
  <div class="relative">
    {% if thumbnail %}
      <img src="{{ thumbnail }}" alt="{{ thumbnailAlt }}" class="w-full h-auto aspect-video object-cover">
    {% else %}
      <div class="bg-lighter aspect-video w-full flex items-center justify-center">
        <span class="text-muted text-sm">No preview available</span>
      </div>
    {% endif %}

    {# Label #}
    {% if label %}
      <span class="absolute top-sm right-sm bg-blue text-dark px-sm py-xs text-xs">
        {{ label }}
      </span>
    {% endif %}
  </div>

  {# Content #}
  <div class="p-md flex flex-col flex-grow">
    {# Version #}
    {% if version %}
      <p class="text-xs text-muted mb-xs">{{ version }}</p>
    {% endif %}

    {# Title #}
    <h3 class="text-xl md:text-2xl font-normal mb-sm">{{ title }}</h3>

    {# Description #}
    <p class="text-sm md:text-base text-dark mb-lg grow">{{ description }}</p>

    {# Action Buttons #}
    <div class="flex flex-col lg:flex-row gap-xs mt-auto">
      {# Primary Action #}
      {% if primaryAction and primaryAction.url %}
        <a
          href="{{ primaryAction.url }}"
          class="inline-block text-center border-2 border-dark bg-dark text-light px-md py-sm hover:bg-darker transition-fast"
        >
          {{ primaryAction.text }}
        </a>
      {% elif primaryAction %}
        <button
          class="text-center border-2 border-dark bg-muted text-dark px-md py-sm cursor-not-allowed"
          disabled
        >
          {{ primaryAction.text }}
        </button>
      {% endif %}

      {# Secondary Action #}
      {% if secondaryAction and secondaryAction.url %}
        <a
          href="{{ secondaryAction.url }}"
          class="inline-block text-center border-2 border-dark bg-light text-dark px-md py-sm hover:bg-lighter transition-fast"
        >
          {{ secondaryAction.text }}
        </a>
      {% elif secondaryAction %}
        <button
          class="text-center border-2 border-dark bg-lighter text-muted px-md py-sm cursor-not-allowed"
          disabled
        >
          {{ secondaryAction.text }}
        </button>
      {% endif %}
    </div>
  </div>
</div>