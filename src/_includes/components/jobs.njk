{% macro jobs(title = "Open Positions", jobsData = []) %}
  {% if jobsData and jobsData.length > 0 %}
    {% set activeJobs = jobsData | selectattr("active", "equalto", true) | list %}
  {% else %}
    {% set activeJobs = [] %}
  {% endif %}

  {% if activeJobs.length > 0 %}
  <section class="px-lg py-xl md:px-2xl bg-dark text-blonde mb-3xl md:mb-6xl">
    <div class="max-w-[1400px] mx-auto px-0 md:px-md">
      <h2 class="text-2xl md:text-3xl lg:text-5xl font-normal mb-xl">{{ title }}</h2>

      <div class="grid grid-cols-1 gap-y-2xl">
        {% for job in activeJobs %}
        <div class="border-t border-blonde pt-lg">
          <h3 class="text-xl md:text-2xl font-bold mb-sm">{{ job.title }}</h3>
          <p class="text-xs md:text-base mb-md">{{ job.description }}</p>
          <a href="mailto:jobs@rebuild.net?subject=Application: {{ job.title | urlencode }}"
             class="inline-block px-md py-sm bg-blonde text-dark font-bold text-sm md:text-base hover:bg-opacity-90 transition-colors">
            Apply with CV
          </a>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
{% endmacro %}
