{#
  Builder Row Component
  Usage: {% include "components/builder-row.njk" %}

  Parameters:
  - builder: Builder object with name, link, category, country, description, tags, etc.
  - expandable: Boolean - whether the row can be expanded (default: true)
#}

{% set isExpandable = expandable if expandable is defined else 
  true %}

<div class="builder-row bg-lighter p-lg" data-builder-id="{{ builder.id }}">
  <div class="builder-row-header flex flex-row items-center justify-between gap-md {% if isExpandable %}cursor-pointer{% endif %}">
    {# Name #}
    <h3 class="text-3xl font-normal">
      <a href="{{ builder.link }}" target="_blank" rel="noopener noreferrer" class="text-dark hover:underline break-all" {% if isExpandable %}onclick="event.stopPropagation()"{% endif %}>
        {{ builder.name }}
      </a>
    </h3>

    {# Expand/Collapse Button #}
    {% if isExpandable %}
      <button class="builder-toggle shrink-0 text-3xl leading-none" aria-label="Toggle details">
        <svg class="builder-icon-plus w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        <svg class="builder-icon-minus w-12 h-12 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    {% endif %}
  </div>

  {# Expandable Content #}
  <div class="builder-row-content {% if isExpandable %}hidden{% endif %} mt-lg">
    {# URL #}
    {# {% if builder.link %}
      <div class="mb-md">
        <a href="{{ builder.link }}" target="_blank" rel="noopener noreferrer" class="text-darker underline hover:text-blue break-all" {% if isExpandable %}onclick="event.stopPropagation()"{% endif %}>
          {{ builder.link }}
        </a>
      </div>
    {% endif %} #}

    {# Description #}
    {% if builder.description %}
      <div class="mb-md text-base leading-tight">
        <p>{{ builder.description }}</p>
      </div>
    {% endif %}

    <div class="flex flex-row justify-between mt-xl">
      {# Tags #}
      {% if builder.category and builder.category.length > 0 %}
        <div class="flex gap-xs flex-wrap mb-md">
          {% for cat in builder.category %}
            {% set colors = [cat] | categoryColors %}
            <span class="inline-block px-md py-xs {{ colors.bg }} {{ colors.text }} text-sm">{{ cat }}</span>
          {% endfor %}
        </div>
      {% endif %}

      {# Country #}
      {% if builder.country and builder.country.length > 0 %}
        <div class="text-sm">
          From {{ builder.country | join(", ") }}
        </div>
      {% endif %}
    </div>
  </div>
</div>