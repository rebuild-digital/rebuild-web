{#
  Builder Row Component
  Usage: {% include "components/builder-row.njk" %}

  Parameters:
  - builder: Builder object with name, link, category, country, description, tags, etc.
#}

<div class="builder-row bg-lighter p-md lg:p-lg" data-builder-id="{{ builder.id }}">
  <div class="builder-row-header flex flex-row items-center justify-between gap-md">
    {# Name #}
    <h3 class="text-3xl font-normal">
      <a href="{{ builder.link }}" target="_blank" rel="noopener noreferrer" class="text-dark break-all">
        {{ builder.name }}
      </a>
    </h3>
  </div>

  {# Content #}
  <div class="builder-row-content mt-0">
    {# URL #}
    {% if builder.link %}
      <div class="mb-md">
        <a href="{{ builder.link }}" target="_blank" rel="noopener noreferrer" class="text-darker text-xs underline break-all">
          {{ builder.link }}
        </a>
      </div>
    {% endif %}

    {# Description #}
    {% if builder.description %}
      <div class="mb-md text-base max-w-[55ch] leading-tight">
        <p>{{ builder.description }}</p>
      </div>
    {% endif %}

    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-sm lg:gap-0 mt-lg md:mt-xl">
      {# Tags #}
      {% if builder.category and builder.category.length > 0 %}
        <div class="flex gap-xs flex-wrap">
          {% for cat in builder.category %}
            {% set colors = [cat] | categoryColors %}
            <span class="inline-block px-md py-xs {{ colors.bg }} {{ colors.text }} text-sm">{{ cat }}</span>
          {% endfor %}
        </div>
      {% endif %}

      {# Country #}
      {% if builder.country and builder.country.length > 0 %}
        <div class="text-xs text-darker">
          Built from {{ builder.country | join(", ") }}
        </div>
      {% endif %}
    </div>
  </div>
</div>