{#
  Directory Preview Component
  Usage: {% include "components/directory-preview.njk" %}

  Displays 10 randomly selected platforms from the directory
#}

{% set totalPlatforms = builders | length %}
{% set randomPlatforms = builders | shuffle | limit(10) %}

<section class="relative w-full py-4xl bg-blue" style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
  <div class="max-w-[1400px] mx-auto px-md">

    {# Header #}
    <div class="flex justify-between flex-col md:flex-row gap-lg md:gap-md md:items-center mb-2xl">
      <div>
        <h2 class="text-4xl md:text-5xl font-normal text-dark">Social Platform Directory</h2>
        <p class="text-dark text-sm mt-4">
          Latest count: {{ totalPlatforms }} platforms</p>
      </div>
      <a href="/directory/" class="text-lg md:text-2xl text-dark hover:underline transition-fast">View all</a>
    </div>

    {# Platform List #}
    {% if randomPlatforms and randomPlatforms | length > 0 %}
      <div class="space-y-0">
        {% for platform in randomPlatforms %}
          <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-dark py-sm">
            {# Name #}
            <h3 class="text-2xl md:mb-0 md:text-4xl font-normal text-dark">
              <a href="{{ platform.link }}" target="_blank" rel="noopener noreferrer" class="hover:underline transition-fast break-all">
                {{ platform.name }}
              </a>
            </h3>

            {# Categories #}
            <div class="flex flex-wrap md:justify-end gap-xs">
              {% for category in platform.category %}
                <span class="text-sm text-dark">{{ category }}
                  {% if not loop.last %}, {% endif %}
                </span>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="py-xl">
        <p class="text-lg text-dark">No platforms available. Total platforms: {{ totalPlatforms }}</p>
      </div>
    {% endif %}

    {# Footer #}
    <div class="mt-xl md:mt-3xl flex flex-col md:flex-row justify-end items-start md:items-center gap-lg">
      {# Count #}
      {# <p class="text-base max-w-96 md:text-lg text-dark">
        Among {{ totalPlatforms - 10 }} other social platforms we've listed, so far.
      </p> #}

      {# CTAs #}
      <div class="flex gap-sm md:gap-md">
        <button data-form="builder-application" class="inline-block px-sm md:px-lg py-xs md:py-md bg-dark border-2 border-dark text-light hover:underline transition-all duration-fast focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue cursor-pointer">
          Join the directory
        </button>
        <button data-form="builder-promo" class="inline-block px-sm md:px-lg py-xs md:py-md bg-transparent border-2 border-dark text-dark hover:underline transition-all duration-fast focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue cursor-pointer">
          Suggest a platform
        </button>
      </div>
    </div>

  </div>
</section>