{#
  Builder Promotion Form
  Usage: {% include "components/builder-promo-form.njk" %}

  This form allows users to promote a builder to the Rebuild catalog.
  Submissions are sent to a Notion database via Bunny Edge Script.

  Parameters:
  - title: Form title (optional, default provided)
  - description: Form description (optional, default provided)
#}

{% set formTitle = title | default('Promote a Builder') %}
{% set formDescription = description | default('Know an amazing builder who should be in our catalog? Let us know about them!') %}

{% set builderPromoFields = [
  {
    type: 'text',
    name: 'builder_name',
    label: 'Builder or Organization Name',
    placeholder: 'Acme Rebuilders Co.',
    required: true,
    helpText: 'The name of the person or organization you want to promote'
  },
  {
    type: 'url',
    name: 'builder_website',
    label: 'Website or LinkedIn',
    placeholder: 'https://example.com',
    required: true,
    helpText: 'Where can we learn more about this builder?'
  },
  {
    type: 'select',
    name: 'builder_category',
    label: 'Category',
    required: true,
    options: [
      'Technology & Software',
      'Social Enterprise',
      'Community Building',
      'Education & Training',
      'Policy & Advocacy',
      'Arts & Culture',
      'Environment & Sustainability',
      'Other'
    ]
  },
  {
    type: 'textarea',
    name: 'why_promote',
    label: 'Why should they be in the catalog?',
    placeholder: 'Tell us what makes this builder special and how they are contributing to rebuilding social infrastructure...',
    required: true,
    rows: 6,
    helpText: 'Share what impact they are making and why the Rebuild community should know about them'
  },
  {
    type: 'text',
    name: 'your_name',
    label: 'Your Name',
    placeholder: 'Your name',
    required: true
  },
  {
    type: 'email',
    name: 'your_email',
    label: 'Your Email',
    placeholder: 'your@email.com',
    required: true,
    helpText: 'We may contact you if we need more information'
  },
  {
    type: 'text',
    name: 'your_relationship',
    label: 'Your Relationship to Builder',
    placeholder: 'e.g., colleague, friend, community member',
    required: false,
    helpText: 'Optional: How do you know this builder?'
  }
] %}

{% set formId = 'builder-promo-form' %}
{% set action = '/api/builder-promotion' %}
{% set method = 'POST' %}
{% set title = formTitle %}
{% set description = formDescription %}
{% set submitText = 'Submit Promotion' %}
{% set submitVariant = 'primary' %}
{% set fields = builderPromoFields %}
{% set successMessage = 'Thank you for the recommendation! We will review this builder for inclusion in our catalog.' %}
{% set errorMessage = 'Sorry, we could not submit your promotion. Please try again or contact us directly.' %}
{% include "components/form.njk" %}
