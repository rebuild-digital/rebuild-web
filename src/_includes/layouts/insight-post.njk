---
layout: layouts/base.njk
---

{% block content %}
<article class="pt-xl pb-2xl">
  <header class="mb-xl">
    <h1>{{ title }}</h1>

    <div class="post-meta flex gap-md align-center mb-md">
      {% if date %}
        <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
      {% endif %}
      {% if author %}
        <span class="author">By {{ author }}</span>
      {% endif %}
    </div>

    {% if tags %}
      <div class="post-tags flex gap-sm flex-wrap mb-md">
        {% for tag in tags %}
          <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
    {% endif %}

    {% if featured_image %}
      <div class="featured-image mb-lg">
        <img src="{{ featured_image }}" alt="{{ title }}" loading="lazy">
      </div>
    {% endif %}
  </header>

  <div class="post-content rich-text">
    {{ content | safe }}
  </div>
</article>
{% endblock %}
