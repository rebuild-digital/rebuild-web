---
layout: layouts/base.njk
---

{% block content %}
<article class="pt-xl pb-2xl">
  {% if featured_image %}
    <div class="featured-image mb-xl -mx-md">
      <img src="{{ featured_image }}" alt="{{ title }}" loading="lazy" class="w-full h-auto rounded-md">
    </div>
  {% endif %}

  <div class="mx-auto max-w-[75ch]">
    <header class="">
      <h1 class="text-5xl mb-md">{{ title }}</h1>

      <div class="post-meta flex gap-md items-center mb-md text-muted">
        {% if date %}
          <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
        {% endif %}
        {% if author %}
          <span class="author">By {{ author }}</span>
        {% endif %}
      </div>

      {% if tags %}
        <div class="post-tags flex gap-sm flex-wrap mb-md">
          {% for tag in tags %}
            <span class="tag px-sm py-xs bg-light border border-dark text-xs rounded-sm">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </header>

    <div class="post-content rich-text">
      {{ content | safe }}
    </div>
  </div>
</article>
{% endblock %}
