---
layout: layouts/base.njk
---

{% block content %}
  <article class="pb-2xl">
    {% if featured_image %}
      <div class="featured-image mb-xl w-full max-h-[900px]">
        <img src="{{ featured_image }}" alt="{{ title }}" loading="lazy" class=" h-auto">
      </div>
    {% endif %}

    <div class="mx-auto max-w-[75ch] relative">
      <header class="">
        <h1 class="text-5xl leading-none mb-md">{{ title }}</h1>

        <div class="flex gap-md text-sm items-center mb-md text-muted">
          {% if date %}
            <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
          {% endif %}
          {% if author %}
            <span class="author">By {{ author }}</span>
          {% endif %}
        </div>

        {% if tags %}
          <div class="post-tags flex gap-xs flex-wrap mb-2xl">
            {% for tag in tags %}
              <span class="p-xs bg-light border border-dark text-xs">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </header>

      <div class="post-content rich-text">
        {{ content | safe }}
      </div>
    </div>
  </article>
{% endblock %}