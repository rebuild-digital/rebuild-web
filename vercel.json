{
  "headers": [
    {
      "source": "/includes/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://letter.rebuild.net"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=600"
        }
      ]
    }
  ]
}
