{
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@notionhq/client": "^5.4.0",
    "@tailwindcss/postcss": "^4.0.0",
    "dotenv": "^17.2.3"
  },
  "name": "rebuild-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:css & eleventy --serve --watch",
    "dev:css": "tailwindcss -i ./src/styles/main.css -o ./dist/styles/main.css --watch",
    "build": "npm run build:eleventy && npm run build:css && npm run minify",
    "build:eleventy": "NODE_ENV=production eleventy",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./dist/styles/main.css --minify",
    "minify": "npm run minify:js",
    "minify:js": "terser dist/**/*.js --compress --mangle -o dist/bundle.min.js",
    "serve": "eleventy --serve",
    "clean": "rm -rf dist .cache"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:62166/git/mortenbjoern/rebuild-web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tailwindcss/cli": "^4.1.17",
    "autoprefixer": "^10.4.22",
    "cssnano": "^7.1.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1"
  }
}
